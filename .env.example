# LLM Provider: "ollama" hoặc "gemini"
AI_PROVIDER=ollama

# Ollama settings
OLLAMA_HOST=http://localhost:11434
MODEL_NAME=kimi2.6
# API key nếu Ollama endpoint yêu cầu Bearer auth (để trống nếu local không cần)
OLLAMA_API_KEY=

# Gemini settings (free tier, dùng khi AI_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# App
ENV=local
